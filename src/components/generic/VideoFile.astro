---
interface Props {
  src: string;
  type?: string;
  controls?: boolean;
  autoplay?: boolean;
  muted?: boolean;
  loop?: boolean;
  playsinline?: boolean;
  preload?: 'none' | 'metadata' | 'auto';
  poster?: string;
  maxWidth?: string;
  caption?: string;
  class?: string;
}

const {
  src,
  type = 'video/mp4',
  controls = true,
  autoplay = false,
  muted = false,
  loop = false,
  playsinline = true,
  preload = 'metadata',
  poster,
  maxWidth = '100%',
  caption,
  class: className,
} = Astro.props as Props;
---

{
  caption ? (
    <figure>
      <video
        class:list={['content-video', className]}
        style={{ '--video-max-width': maxWidth }}
        controls={controls}
        autoplay={autoplay}
        muted={muted}
        loop={loop}
        playsinline={playsinline}
        preload={preload}
        poster={poster}
      >
        <source src={src} type={type} />
      </video>
      <figcaption>{caption}</figcaption>
    </figure>
  ) : (
    <video
      class:list={['content-video', className]}
      style={{ '--video-max-width': maxWidth }}
      controls={controls}
      autoplay={autoplay}
      muted={muted}
      loop={loop}
      playsinline={playsinline}
      preload={preload}
      poster={poster}
    >
      <source src={src} type={type} />
    </video>
  )
}
