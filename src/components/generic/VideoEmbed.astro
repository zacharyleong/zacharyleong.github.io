---
interface Props {
  src: string;
  title?: string;
  aspectRatio?: string;
  maxWidth?: string;
  allow?: string;
  loading?: 'lazy' | 'eager';
  class?: string;
}

const {
  src,
  title = 'Embedded video',
  aspectRatio = '16 / 9',
  maxWidth = '100%',
  allow = 'autoplay; fullscreen; encrypted-media; picture-in-picture',
  loading = 'lazy',
  class: className,
} = Astro.props as Props;
---

<div
  class:list={['content-video-frame', className]}
  style={{
    '--video-aspect-ratio': aspectRatio,
    '--video-max-width': maxWidth,
  }}
>
  <iframe
    src={src}
    title={title}
    loading={loading}
    allow={allow}
    allowfullscreen
  ></iframe>
</div>
